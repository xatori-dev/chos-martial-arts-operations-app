# App
APP_ENV=local
APP_URL=http://127.0.0.1:5173

# GitHub Pages
GITHUB_REPOSITORY=

# Supabase
# Browser-safe. Use a Supabase publishable key or legacy anon key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Developer prototype login
# Browser-safe flag. Set to true only for local/staging builds that should expose Dev123.
VITE_ENABLE_DEVELOPER_ACCOUNT=

# Server-only. Never place privileged Supabase keys in Vite-exposed variables.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Stripe
# Reserved for a future private backend or checkout integration.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio
# Server-only. Never place these in Vite-exposed variables or browser localStorage.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=

# Web Push
# VAPID_PRIVATE_KEY is server-only. The browser may receive only the public key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=chos-martial-arts-operations-app
CLOUDFLARE_API_WORKER=xd-chos-martial-arts-operations-app-api

# Analytics and Monitoring
SENTRY_DSN=
ANALYTICS_PROVIDER=
